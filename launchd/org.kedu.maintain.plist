<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>org.kedu.maintain</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>KEDU_HOME</key>
    <string>__KEDU_HOME__</string>
  </dict>
  <key>ProgramArguments</key>
  <array>
    <string>__KEDU_PYTHON__</string>
    <string>__KEDU_SCRIPT__</string>
    <string>maintain</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>3</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>__LOG_DIR__/kedu-maintain.log</string>
  <key>StandardErrorPath</key>
  <string>__LOG_DIR__/kedu-maintain.err</string>
</dict>
</plist>
